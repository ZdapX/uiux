{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/modern-style.css",
      "dest": "/modern-style.css"
    },
    {
      "src": "/(.*)",
      "dest": "api/index.js"
    }
  ]
}
